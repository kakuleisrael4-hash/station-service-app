# =====================================================================
#  STATION KKC OIL — Configuration
# =====================================================================
# L'application fonctionne SANS ces variables : elle bascule alors sur
# un magasin local temps-réel (localStorage) avec des données de démo.
#
# Pour passer en PRODUCTION temps réel, créez un projet Supabase gratuit
# (https://supabase.com), exécutez supabase/schema.sql + supabase/rls.sql
# dans le SQL Editor, puis renseignez les deux variables ci-dessous et
# redémarrez `npm run dev`. Le code détecte automatiquement Supabase.
# ---------------------------------------------------------------------

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
